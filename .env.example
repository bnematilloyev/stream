# Application
APP_ENV=development
LOG_LEVEL=debug

# API Gateway
GATEWAY_HTTP_ADDR=:8080
GATEWAY_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# Auth Service
AUTH_GRPC_ADDR=:50051
AUTH_HTTP_ADDR=:9081
AUTH_SERVICE_ADDR=localhost:50051
USER_SERVICE_ADDR=localhost:50052
USER_GRPC_ADDR=:50052
USER_HTTP_ADDR=:9082
STREAM_SERVICE_ADDR=localhost:50053
STREAM_GRPC_ADDR=:50053
STREAM_HTTP_ADDR=:9083
RTMP_BASE_URL=rtmp://127.0.0.1:1935/live
SRT_BASE_URL=srt://127.0.0.1:9000

# Media Pipeline
MEDIA_HTTP_ADDR=:9084
STREAM_SERVICE_ADDR=localhost:50053
RTMP_INTERNAL_URL=rtmp://127.0.0.1:1935/live
HLS_OUTPUT_DIR=./data/hls
HLS_BASE_URL=http://localhost:8090/hls
FFMPEG_PATH=ffmpeg
RTSP_INTERNAL_URL=rtsp://127.0.0.1:8554
WHIP_BASE_URL=http://localhost:8889

# Frontend (frontend/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:8080

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# PostgreSQL
DATABASE_URL=postgres://sahiy:sahiy_secret@localhost:5433/sahiy_stream?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# NATS
NATS_URL=nats://localhost:4222

# MinIO (S3-compatible)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=sahiy_minio
MINIO_SECRET_KEY=sahiy_minio_secret
MINIO_BUCKET=sahiy-media
MINIO_USE_SSL=false
