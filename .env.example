# Application
APP_ENV=development
LOG_LEVEL=debug

# API Gateway
GATEWAY_HTTP_ADDR=:8080
GATEWAY_CORS_ORIGINS=https://stream.vibrant.uz,http://localhost:3000

# Auth Service
AUTH_GRPC_ADDR=:50051
AUTH_HTTP_ADDR=:9081
AUTH_SERVICE_ADDR=localhost:50051
USER_SERVICE_ADDR=localhost:50052
USER_GRPC_ADDR=:50052
USER_HTTP_ADDR=:9082
STREAM_SERVICE_ADDR=localhost:50053
STREAM_GRPC_ADDR=:50053
STREAM_HTTP_ADDR=:9083
CHAT_SERVICE_ADDR=localhost:50054
CHAT_GRPC_ADDR=:50054
CHAT_HTTP_ADDR=:9085
CHAT_RATE_LIMIT_PER_SEC=5
RTMP_BASE_URL=rtmp://127.0.0.1:1935/live
SRT_BASE_URL=srt://127.0.0.1:9000

# Media Pipeline
MEDIA_HTTP_ADDR=:9084
MEDIA_HOOK_SECRET=dev-media-hook-secret-min-32-chars!!
HLS_STORAGE_BACKEND=local
FFMPEG_VIDEO_ENCODER=libx264
TRANSCODE_QUALITY=production
PLAYBACK_BASE_URL=http://localhost:9083
PLAYBACK_SIGNING_SECRET=dev-playback-signing-secret-min-32!!
PLAYBACK_URL_TTL=4h
CDN_BASE_URL=
MINIO_REGION=us-east-1
RTMP_INTERNAL_URL=rtmp://127.0.0.1:1935/live
HLS_OUTPUT_DIR=./data/hls
HLS_BASE_URL=http://localhost:8090/hls
FFMPEG_PATH=ffmpeg
TRANSCODE_MODE=local
RTSP_INTERNAL_URL=rtsp://127.0.0.1:8554

# production = 3-tier high bitrate (VPS, few viewers)
# balanced   = 4-tier default ladder (scale mode)

# Transcode worker (used when TRANSCODE_MODE=queue)
WORKER_HTTP_ADDR=:9086
WORKER_MAX_JOBS=4
WORKER_ID=transcode-worker-1
WHIP_BASE_URL=http://localhost:8889

# Frontend (frontend/.env.local — build vaqtida deploy.sh beradi)
NEXT_PUBLIC_API_URL=https://api.stream.vibrant.uz
NEXT_PUBLIC_WHIP_BASE_URL=https://api.stream.vibrant.uz
NEXT_PUBLIC_HLS_BASE_URL=https://api.stream.vibrant.uz/hls

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
AUTH_USER_CACHE_TTL=5m
GRPC_REQUEST_TIMEOUT=10s

# Gateway tuning
GATEWAY_RATE_LIMIT_RPM=100
GATEWAY_RATE_LIMIT_LOGIN=5
GATEWAY_RATE_LIMIT_REGISTER=3
GATEWAY_RATE_LIMIT_HEARTBEAT=6000
GATEWAY_MAX_BODY_BYTES=1048576

# Stream service
STREAM_STALE_CLEANUP_INTERVAL=30s
VIEWER_HEARTBEAT_WINDOW=45s
VIEWER_SYNC_INTERVAL=15s
DB_MAX_CONNS=25
DB_MIN_CONNS=5

# PostgreSQL (via PgBouncer in production: port 6432)
DATABASE_URL=postgres://sahiy:sahiy_secret@localhost:5433/sahiy_stream?sslmode=disable
DATABASE_REPLICA_URL=

# Redis (standalone or cluster)
REDIS_URL=redis://localhost:6379/0
REDIS_CLUSTER_ADDRS=
REDIS_POOL_SIZE=20

# ClickHouse analytics (optional)
CLICKHOUSE_ENABLED=false
CLICKHOUSE_ADDR=localhost:9009
CLICKHOUSE_DATABASE=sahiy_analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# NATS
NATS_URL=nats://localhost:4222

# MinIO (S3-compatible)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=sahiy_minio
MINIO_SECRET_KEY=sahiy_minio_secret
MINIO_BUCKET=sahiy-media
MINIO_USE_SSL=false
